PROJECT_NAME           = "ASql"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Async SQL library for Qt"

OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIR@

# Input
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/src
FILE_PATTERNS          = *.h *.hpp
RECURSIVE              = NO
EXCLUDE_PATTERNS       = *_p.h *Private* ADriver*.h ADriver*.hpp

# Extract everything public
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO

# Qt tag file so Doxygen links to Qt docs online
TAGFILES               = @DOXYGEN_QT_TAGFILE@=https://doc.qt.io/qt-6/

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

# Graphs
HAVE_DOT               = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = YES

# Misc
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
