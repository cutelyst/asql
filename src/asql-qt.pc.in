prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/asql@PROJECT_VERSION_MAJOR@-qt@QT_VERSION_MAJOR@/ASql

Name: asql@PROJECT_VERSION_MAJOR@-qt@QT_VERSION_MAJOR@
Description: Async Sql library for Qt@QT_VERSION_MAJOR@
Version: @PROJECT_VERSION@
Requires: Qt@QT_VERSION_MAJOR@Core
Libs: -L${libdir} -lASql@PROJECT_VERSION_MAJOR@Qt@QT_VERSION_MAJOR@
Cflags: -I${includedir}
